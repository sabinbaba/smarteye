# Docker build context ignore file
# Exclude unnecessary files from Docker build

# Git and version control
.git
.gitignore
.gitattributes

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Log files
*.log
logs/
attack_logs.log

# Database files (should be volume mounted)
*.db
ids_auth.db
database.db

# Docker files
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
README.md
*.md
docs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Node modules (if any)
node_modules/
npm-debug.log*

# Temporary files
tmp/
temp/
.tmp/

# Model files (should be volume mounted in production)
model/
*.h5
*.pkl
*.pkl.gz

# Backup files
*.bak
*.backup
*~

# Development files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Monitoring config (if separate)
monitoring/

# Other
*.tar.gz
*.zip
*.rar
