# Environment Configuration for Hybrid IDS Application

# Application Settings
FLASK_ENV=development
FLASK_DEBUG=1
PYTHONUNBUFFERED=1

# Network Interface Configuration
# Change this to your network interface (e.g., eth0, wlan0, any)
NETWORK_INTERFACE=any

# Application Ports
PORT=8090

# IDS Configuration
MAX_PACKETS=5000
DOS_PPS_THRESHOLD=500
DDOS_SOURCE_THRESHOLD=5
DDOS_TOTAL_PPS=1500

# Security Settings
SECRET_KEY=hybrid-ids-secret-key-change-in-production-2024
SESSION_TYPE=filesystem
SESSION_PERMANENT=true
PERMANENT_SESSION_LIFETIME=24

# Database Configuration
DATABASE_PATH=/app/ids_auth.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/app/attack_logs.log

# Machine Learning Configuration
ML_ENABLED=true
MODEL_PATH=/app/model

# Redis Configuration (for caching)
REDIS_URL=redis://redis:6379/0

# Build Information (for container metadata)
BUILD_DATE=${BUILD_DATE}
VCS_REF=${VCS_REF}
VERSION=${VERSION:-latest}

# Development Settings
# Set to true to enable development features
DEVELOPMENT_MODE=true
AUTO_RELOAD=true

# Container Resource Limits
CONTAINER_CPU_LIMIT=2.0
CONTAINER_MEMORY_LIMIT=2G

# Network Configuration
NETWORK_SUBNET=172.20.0.0/16

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
BACKUP_RETENTION=7

# Monitoring Configuration (optional)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# SSL/TLS Configuration (for production)
SSL_ENABLED=false
SSL_CERT_PATH=/app/ssl/cert.pem
SSL_KEY_PATH=/app/ssl/key.pem

# Email Configuration (for alerts)
EMAIL_ENABLED=false
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@hybrid-ids.local

# External Integrations
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_SECRET=

# Feature Flags
ENABLE_REAL_TIME_PACKET_CAPTURE=true
ENABLE_ML_DETECTION=true
ENABLE_USER_AUTHENTICATION=true
ENABLE_ATTACK_LOGGING=true
ENABLE_DASHBOARD_ANALYTICS=true

# Performance Tuning
THREAD_POOL_SIZE=10
REQUEST_TIMEOUT=30
MAX_REQUEST_SIZE=16777216

# Development Tools
DEBUG_TOOLBAR_ENABLED=true
PROFILER_ENABLED=false
SQL_DEBUG=false
